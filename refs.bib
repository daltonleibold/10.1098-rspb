@Article{Dees_et_al_2020,
  author    = {Dees, Allison and Wilson, Kayla and Reali, Chanel and Pruett, Jenna E. and Hall, Joshua M. and Brandt, Renata and Warner, Daniel A.},
  journal   = {Ethology},
  title     = {Communal egg‐laying behaviour and the consequences of egg aggregation in the brown anole (Anolis sagrei)},
